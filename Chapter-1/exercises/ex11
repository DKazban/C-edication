int getline(char s[], int lim) {
	int c, i;
	for (i = 0;(c = getchar()) != EOF && c != '\n';i++) {
		if (i < lim - 1) {
		s[i] = c;
		}
	}
	
	if (c == '\n') {
		if (i < lim - 1)
		s[i] = c;
		i++;
	}
	
	
	if (i < lim)
	s[i] = '\0';
	else
	s[lim-1] = '\0';
	return i;
}

