# include <stdio.h>

# define MAXLINE 1000

int getline(char longest[], int maxline);
void copy(char to[], char from[]);

int main () {
	int len;
	char line[MAXLINE];

	while((len = getline(line, MAXLINE)) > 0) {
		int i = len - 2;
		
		while (i >= 0 && (line[i] == ' ' || line[i] == '\t'))
			--i;
		
		line[i+1] = '\n';
		line[i+2] = '\0';
		
		
		if (i >= 0)
			printf("%s", line);
	}
	return 0;
}

int getline(char s[], int lim) {
	int c, i;
	for (i = 0;(c = getchar()) != EOF && c != '\n';i++) {
		if (i < lim - 1) {
		s[i] = c;
		}
	}
	
	if (c == '\n') {
		if (i < lim - 1)
		s[i] = c;
		i++;
	}
	
	
	if (i < lim)
	s[i] = '\0';
	else
	s[lim-1] = '\0';
	return i;
	
	 
}

