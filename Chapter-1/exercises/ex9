Temperature converter with function and formatted output
--------------------------------------------------------------
#include <stdio.h>

float celsium(float fahr);

int main() {
	float fahr;
	int lower,upper, step;
	
	lower = 0;
	upper = 300;
	step = 20;
	
	fahr = lower;
	printf("Fahr	Celsius\n");
	
	while (fahr <= upper) {
		printf("%3.0f %6.1f\n", fahr, celsium(fahr));
		fahr = fahr + step;
	}
	
	return 0;
}

float celsium(float fahr) {
	return (5.0/9.0) * (fahr - 32);
}
