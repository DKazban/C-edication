Find the index of a character in a string
----------------------------------------

#include <stdio.h>

int any(char s1[], char s2[]);

int main () {
	
	char text[] = "apple";
	char pattern[] = "pe";
	
	int result = any(text, pattern);
		
	printf("the index of the character we are looking for “%s” in the string “%s”: %d",pattern,text, result);

	return 0;
}

int any(char s1[], char s2[]) {
	int i = 0;

	while (s1[i] != '\0') {
		int k = 0;
		
		while(s2[k] != s1[i] && s2[k] != '\0') {
			k++;
		}
		
		if(s1[i] == s2[k]) {
				return i;
		}
		i++;
	}
	
	return -1;
	
}
