Return the remainder of an array from which matching 
characters have been removed from another array
----------------------------------------------------------
#include <stdio.h>

void squeeze();

int main () {
	
	char text[] = "apple";
	char pattern[] = "pe";
	
	squeeze(text, pattern);
		
	printf("the rest of 'apple', when 'pe' is prohibited: %s", text);

	return 0;
}

void squeeze(char s1[], char s2[]) {
	int i = 0;
	int j = 0;
	
	while (s1[i] != '\0') {
		int k = 0;
		
		while(s2[k] != s1[i] && s2[k] != '\0') {
			k++;
		}
		
		if(s2[k] == '\0') {
				s1[j] = s1[i];
				j++;
		}
		i++;
	}
	
	s1[j] = '\0';
}
