#include <stdio.h>

int digits;
int spaces;
int total;

void analyze(int c);
void report(void);

int main () {
	int c;
	while ((c = getchar()) != EOF && c != '#') {
		analyze(c);
		++total;
	}
	
	report();
	return 0;
}

void analyze(int c) {
	if (c >= '0' && c <= '9') {
			++digits;
			
		}
		 else if (c == ' ') {
		 	++spaces;
		 	
		 }
}

void report() {
	printf("Digits: %d, Spaces: %d, Total: %d", digits, spaces, total);
	
	if (digits > 3) {
		printf("ok \n");
	}
	
	else {
		printf("nu uh \n");
	}
}
