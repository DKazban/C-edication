#include <stdio.h>

int main() {
	int mag = 30;
	int total = 90;
	char action;
	
	printf("Mag: %d| Total \n: %d",mag, total);
	printf("Press 'F' to fire, 'r' to reload, 'q' to quit \n");
	
	while((action = getchar()) != 'q') {
		if (action == 'f') {
			if (mag > 0) {
				mag--;
				printf("Bang! \n");
			}
			else
			printf("CLICK! NEED TO RELOAD");
		}
		
		else if (action == 'r') {
			int need = 30 - mag;
			if (total >= need) {
				total -= need;
				mag = 30;
				printf("Reloaded! Ready to fire \n");
			}
			
			else
			printf("Not enough ammo");
		}
	}
	
	return 0;
}
